{
  "project": "Finance Analytics Dashboard",
  "version": "1.0.0",
  "theme": {
    "palette": {
      "background": "#0B0E14",
      "surface": "#161B22",
      "border": "#21262D",
      "primary": "#3B82F6",
      "secondary": "#A855F7",
      "accent_cyan": "#06B6D4",
      "success": "#10B981",
      "danger": "#EF4444",
      "text": {
        "primary": "#FFFFFF",
        "secondary": "#8B949E",
        "disabled": "#484F58"
      }
    },
    "spacing": {
      "container_padding": "32px",
      "card_gap": "24px",
      "border_radius": "12px"
    }
  },
  "components": {
    "sidebar": {
      "width": "260px",
      "items": ["Dashboard", "Transactions", "Accounts", "Investments", "Reports", "Settings"]
    },
    "kpi_metrics": [
      { "id": 1, "label": "Total Balance", "value": "$128,430.00", "trend": "+12.5%", "status": "positive" },
      { "id": 2, "label": "Monthly Income", "value": "$45,210.50", "trend": "+8.2%", "status": "positive" },
      { "id": 3, "label": "Total Expenses", "value": "$12,850.20", "trend": "-3.1%", "status": "negative" }
    ],
    "main_chart": {
      "type": "Area",
      "categories": ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
      "series": [
        { "name": "Income", "data": [4500, 5200, 4800, 7100, 6900, 8200], "color": "#3B82F6" },
        { "name": "Expenses", "data": [3100, 2800, 3500, 4100, 3800, 4200], "color": "#A855F7" }
      ]
    },
    "transactions_table": [
      { "entity": "Apple Store", "category": "Tech", "date": "02 Apr", "amount": "-$1,299", "status": "Success" },
      { "entity": "Stripe", "category": "Income", "date": "01 Apr", "amount": "+$4,500", "status": "Pending" },
      { "entity": "Amazon AWS", "category": "Cloud", "date": "28 Mar", "amount": "-$240", "status": "Success" }
    ]
